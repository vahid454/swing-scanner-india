# ── Copy this to .env and fill in your values ─────────────
# cp .env.example .env

# Finnhub API key — free at https://finnhub.io/register
# Used for: OHLCV candles, company news, WebSocket feed
FINNHUB_API_KEY=your_finnhub_api_key_here

# Redis — for local dev, start with: docker compose up -d
# Railway auto-provides this as $REDIS_URL when you add a Redis plugin
REDIS_URL=redis://127.0.0.1:6379

# Server port (Railway/Render override this automatically)
PORT=8786

# Node environment
NODE_ENV=development
